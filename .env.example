# SMTP configuration for intake form emails
# Copy to .env and fill in your credentials (never commit .env)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-app-password

PORT=3000

# NDA pricing gate
# PRICING_CODE is the unlock code you email to NDA-signed customers
# PRICING_SECRET is a random string used to sign HttpOnly cookies (generate with: node -e "require('crypto').randomBytes(32).toString('hex')" | pbcopy)
PRICING_CODE=your-nda-code
PRICING_SECRET=your-random-32-byte-hex-string
